# LLM access — leave OPENROUTER_API_KEY unset (or set LLM_MODE=mock) for the
# deterministic offline mode; the whole pipeline still runs.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
LLM_MODE=

# Simulation
SIM_ENABLED=1
SIM_INTERVAL_S=3

# CORS (comma-separated origins; * for demo)
ALLOWED_ORIGINS=*

# Access gate: set a crew password to require login for any state-changing
# action (decisions, fault injection, LLM toggle). Empty = gate disabled.
# Reading the dashboard is always open — a shared link shows, it can't act.
APP_ACCESS_PASSWORD=

# Hard cap on live-LLM triage runs per UTC day; past it the pipeline degrades
# to the deterministic mock policy instead of spending.
LLM_DAILY_CALL_CAP=40

# SQLAlchemy URL. SQLite for local dev; in production set DATABASE_URL (takes
# precedence) to a Postgres DSN, e.g. the Supabase pooler:
#   DATABASE_URL=postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:6543/postgres
# On Postgres the app lives in its own schema (default pm_triage; override with
# PM_TRIAGE_DB_SCHEMA) so it can share an instance safely.
PM_TRIAGE_DB_URL=sqlite:///./pm_triage.db
DATABASE_URL=

# Raw telemetry pruning for the always-on deployment (cases/audit never pruned)
TELEMETRY_RETENTION_HOURS=24
